{
  "name": "angular-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\" \"angular.json\" \"package.json\" \"tsconfig*.json\" \".prettierrc\" \"README.md\"",
    "format:write": "prettier --write \"src/**/*.{ts,html,scss}\" \"angular.json\" \"package.json\" \"tsconfig*.json\" \".prettierrc\" \"README.md\"",
    "lint": "npm run typecheck && npm run format:check",
    "prepare": "husky"
  },
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
